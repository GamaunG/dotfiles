#!/bin/bash
mkdir -p ~/.local/src/dotfiles; cd ~/.local/src/dotfiles || exit
mkdir -p ./.config ./.local/bin ./extra/{nvim,hooks,cursor}
cp ~/.zshenv ./

rsync -av --delete ~/.config/{shell,zsh,readline,vim,ideavim,nvim,nvimMinimal,wget,htop,npm,fastfetch,lsd,glow,lf,bat,alacritty,fontconfig,mpv,wofi,btop,tmux,hypr,hyprland-per-window-layout,niri,DankMaterialShell,aibox,quickshell,colorschemes,swaync,waybar,MangoHud} ./.config/ --exclude=aliasrc-extra --exclude=shortcutrc --exclude=zshnameddirrc --exclude=*.log --exclude=nvim/lua/shortcuts.lua --exclude=bm-dirs --exclude=bm-files --exclude=nvim/spell

rsync -av ~/.local/bin/{shortcuts,cpcfg,esc,ecf,bwt,rename_by_date,ocr,wofipass,wofipower,vmrss,sqlist,flatpakComparePerms} ./.local/bin/

rm .config/nvim/spell
cp -r ~/.local/share/icons/Bruh ./extra/cursor/

cp /usr/share/libalpm/hooks/dashtobinsh.hook ./extra/hooks/

cp ~/coding/dotfiles/{install.sh,\.gitignore,README.md} ./
ln -s ~/coding/dotfiles/install.sh ./install-link.sh
ln -s ~/coding/dotfiles/README.md ./README-link.md
cp ~/coding/GPLv3_LICENSE ./LICENSE

cp -r ~/coding/dotfiles/{downloads,zorin,wallpaper.jpg,desktop.png,shell,fonttest.html,flatpak-permissions-lockdown.sh} ./extra/

## dms
sed -i "s|\"customThemeFile\": \"/home/$USER/|\"customThemeFile\": \"/home/username/|" ./.config/DankMaterialShell/settings.json
(cd .config/DankMaterialShell && tar -czf plugins.tar.gz plugins) # must be archived to prevent nested git repos
rm -rf .config/DankMaterialShell/plugins

[[ -z "$*" ]] && read -rsen 1 -p "create tar archive? y/N? " answ
[[ "$1" == "-y" ]] && answ="y"
[[ "$answ" == "y" || "$answ" == "Y" ]] && tar -czvf dotfiles.tar.gz --exclude=dotfiles.tar.gz --exclude=install-link.sh --exclude=README-link.md --exclude=.git* --exclude=backup* .
